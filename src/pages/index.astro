---
/**
 * INICIO — Página principal del sitio.
 * Muestra presentación breve, feed de últimas entradas,
 * contadores, y línea de tiempo abierta.
 */
import Base from '../layouts/Base.astro';
import EntryCard from '../components/EntryCard.astro';
import TypeBadge from '../components/TypeBadge.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

// Leer texto de presentación corta
const aboutShortPath = path.resolve('./content/config/about-short.md');
const aboutShortRaw = fs.readFileSync(aboutShortPath, 'utf-8');
const aboutShort = aboutShortRaw
  .replace(/\*\*([^*\_]+)\*\*/g, '<strong>$1</strong>')
  .replace(/__([^_]+)__/g, '<strong>$1</strong>')
  .replace(/\n\n/g, '<br><br>');

// Obtener todas las colecciones y combinar
const archivo = (await getCollection('archivo')).filter(e => !e.data.draft);
const proyectos = (await getCollection('proyectos')).filter(e => !e.data.draft);

const biblioteca = await getCollection('biblioteca');

// Construir un feed unificado con las últimas entradas
type FeedItem = {
  title: string;
  date: Date;
  type: string;
  excerpt: string;
  tags: string[];
  href: string;
  collection: string;
};

const feedItems: FeedItem[] = [
  ...archivo.map(e => ({
    title: e.data.title,
    date: e.data.date,
    type: e.data.type,
    excerpt: e.data.excerpt,
    tags: e.data.tags,
    href: `/ejercicios/${e.id}/`,
    collection: 'archivo',
  })),
  ...proyectos.map(e => ({
    title: e.data.title,
    date: e.data.date,
    type: e.data.discipline,
    excerpt: e.data.excerpt,
    tags: e.data.tags,
    href: `/proyectos/${e.id}/`,
    collection: 'proyectos',
  })),
];

// Ordenar por fecha descendente y tomar las 6 más recientes
const latestEntries = feedItems
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 6);

// Contadores
const totalEntries = archivo.length + proyectos.length;
const totalBooks = biblioteca.length;

---

<Base title="Edwin López — Arquitectura, Ingeniería Civil & Construcción">
  <!-- Presentación -->
  <header class="page-header">
    <h1>Edwin López</h1>
    <p class="page-header__subtitle" set:html={aboutShort} />
  </header>

  <!-- Contadores -->
  <div class="stats-bar">
    <div class="stat">
      <span class="stat__number">{totalEntries}</span>
      <span class="stat__label">Entradas</span>
    </div>
    <div class="stat">
      <span class="stat__number">{totalBooks}</span>
      <span class="stat__label">Literatura</span>
    </div>
  </div>

  <!-- Feed de últimas entradas -->
  <section>
    <h2 style="font-family: var(--font-mono); font-size: var(--fs-sm); text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-soft); margin-bottom: 1.5rem;">
      Últimas entradas
    </h2>
    <ul class="entry-list">
      {latestEntries.map(entry => (
        <li class="entry-list__item">
          <EntryCard
            href={entry.href}
            title={entry.title}
            date={entry.date}
            type={entry.type}
            excerpt={entry.excerpt}
            tags={entry.tags}
          />
        </li>
      ))}
    </ul>
  </section>

  <!-- Línea de tiempo -->
  <div class="timeline">
    2026 →
  </div>
</Base>
