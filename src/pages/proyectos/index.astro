---
/**
 * PROYECTOS & PROCESO — Grid de proyectos académicos y profesionales.
 * Vista de cards con imagen de portada, filtrable por disciplina.
 */
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import TagFilter from '../../components/TagFilter.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('proyectos'))
  .filter(e => !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const disciplines = [...new Set(entries.map(e => e.data.discipline))].sort();
---

<Base title="Proyectos & Proceso — Archivo de Campo" description="Trabajos académicos y profesionales con su proceso documentado.">
  <header class="page-header">
    <h1>Proyectos & Proceso</h1>
    <p class="page-header__subtitle">
      Trabajos académicos y profesionales con su proceso documentado.
    </p>
  </header>

  <TagFilter tags={disciplines} target="#proyectos-grid" />

  <div class="project-grid" id="proyectos-grid">
    {entries.map(entry => (
      <ProjectCard
        href={`/proyectos/${entry.id}/`}
        title={entry.data.title}
        year={entry.data.year}
        type={entry.data.discipline}
        excerpt={entry.data.excerpt}
        cover={entry.data.cover}
      />
    ))}
  </div>
</Base>
