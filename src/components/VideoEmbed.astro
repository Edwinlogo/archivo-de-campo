---
/**
 * VideoEmbed — Embed responsivo de YouTube o Vimeo.
 * Detecta automáticamente la plataforma y genera el iframe.
 * Props: url (URL del video).
 */
interface Props {
  url: string;
}

const { url } = Astro.props;

// Extraer ID de embed según plataforma
function getEmbedUrl(rawUrl: string): string {
  // YouTube
  const ytMatch = rawUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]+)/);
  if (ytMatch) return `https://www.youtube.com/embed/${ytMatch[1]}`;

  // Vimeo
  const vimeoMatch = rawUrl.match(/vimeo\.com\/(\d+)/);
  if (vimeoMatch) return `https://player.vimeo.com/video/${vimeoMatch[1]}`;

  // Si ya es una URL de embed, usarla directamente
  return rawUrl;
}

const embedUrl = getEmbedUrl(url);
---

<div class="video-embed">
  <iframe
    src={embedUrl}
    title="Video embed"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>
