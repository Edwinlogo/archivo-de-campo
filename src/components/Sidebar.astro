---
/**
 * Sidebar — Navegación principal fija a la izquierda.
 * Muestra el nombre del sitio y enlaces a todas las secciones.
 * El enlace activo se determina comparando la URL actual con la ruta.
 */
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/ejercicios/', label: 'Ejercicios de Arquitectura' },
  { href: '/proyectos/', label: 'Proyectos & Proceso' },
  { href: '/literatura/', label: 'Literatura' },
  { href: '/etiquetas/', label: 'Etiquetas' },
  { href: '/sobre/', label: 'Sobre mí' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<aside class="sidebar" aria-label="Navegación principal">
  <div class="sidebar__logo">
    <a href="/">Edwin<br />López</a>
  </div>

  <nav>
    <ul class="sidebar__nav">
      {navItems.map(item => (
        <li>
          <a href={item.href} class={isActive(item.href) ? 'active' : ''}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar__footer">
    Arquitectura &<br />Ingeniería Civil
  </div>
</aside>
